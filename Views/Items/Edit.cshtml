@model MyApp_MVC.Dtos.ItemDto
@{
    ViewData["Title"] = "Edit Item";
}

<link rel="stylesheet" href="~/css/items.css" />

<div class="items-container" style="max-width: 600px;">
    <div class="glass-card">
        <h3>Update Product Details</h3>
        <p style="color: var(--text-muted); margin-bottom: 2rem;">Modify the product information below.</p>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group">
                <label asp-for="Name">Product Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price">Unit Price</label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div style="margin-top: 2rem; display: flex; gap: 1rem;">
                <button type="submit" class="premium-btn">Save Changes</button>
                <a asp-action="GetAllItems" style="text-decoration: none; color: var(--text-muted); display: flex; align-items: center; padding: 0 1rem;">Cancel</a>
            </div>
        </form>
    </div>
</div>