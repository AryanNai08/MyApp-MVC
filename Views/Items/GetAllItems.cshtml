@model IEnumerable<MyApp_MVC.Dtos.ItemDto>
@{
    ViewData["Title"] = "Items Portfolio";
}

<link rel="stylesheet" href="~/css/items.css" />

<div class="items-container">
    <div class="glass-card">
        <div class="title-area">
            <h2>Inventory Management</h2>
            <a asp-action="Create" class="premium-btn">+ New Item</a>
        </div>

        <table class="premium-table">
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th>Price Tag</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span style="font-weight: 600;">@item.Name</span>
                        </td>
                        <td>
                            <span class="badge-price">₹@item.Price.ToString("N2")</span>
                        </td>
                        <td style="text-align: right;" class="action-links">
                            <a asp-action="Edit" asp-route-id="@item.Id">Edit Details</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="link-delete">Remove</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if (!Model.Any())
        {
            <div style="text-align: center; padding: 3rem; color: var(--text-muted);">
                <p>No items found in inventory.</p>
            </div>
        }
    </div>
</div>
