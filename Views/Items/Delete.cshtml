@model MyApp_MVC.Dtos.ItemDto
@{
    ViewData["Title"] = "Delete Confirmation";
}

<link rel="stylesheet" href="~/css/items.css" />

<div class="items-container" style="max-width: 600px;">
    <div class="glass-card" style="border-top: 4px solid var(--danger);">
        <h3 style="color: var(--danger);">Delete Product?</h3>
        <p style="color: var(--text-muted); margin-bottom: 2.5rem;">Are you sure you want to remove <strong>@Model.Name</strong>? This action cannot be undone.</p>

        <div style="background: rgba(255, 255, 255, 0.05); padding: 1.5rem; border-radius: 0.5rem; margin-bottom: 2rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                <span style="color: var(--text-muted);">Name:</span>
                <span style="font-weight: 600;">@Model.Name</span>
            </div>
            <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--text-muted);">Price:</span>
                <span class="badge-price">₹@Model.Price.ToString("N2")</span>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="premium-btn btn-danger">Confirm Delete</button>
                <a asp-action="GetAllItems" style="text-decoration: none; color: var(--text-muted); display: flex; align-items: center; padding: 0 1rem;">Keep Item</a>
            </div>
        </form>
    </div>
</div>